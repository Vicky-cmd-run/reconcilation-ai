# FMCG Reconciliation AI - Environment Configuration
# Copy this file to .env and fill in your values

# ==================== Application Settings ====================
APP_NAME="FMCG Reconciliation AI"
APP_VERSION="1.0.0"
DEBUG=false

# ==================== API Settings ====================
API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,https://reconcilation-ai.vercel.app"

# ==================== File Upload Settings ====================
MAX_FILE_SIZE_MB=10

# ==================== LLM Settings (Google Gemini) ====================
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# LLM Configuration
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3

# Caching
LLM_CACHE_ENABLED=true
LLM_CACHE_SIZE=1000

# ==================== Rate Limiting ====================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100

# ==================== Logging ====================
LOG_LEVEL=INFO
